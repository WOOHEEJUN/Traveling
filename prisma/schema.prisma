// 커플 여행 플래너 - 데이터 모델
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// 앱 사용자 (2명 고정)
/// role은 ASCII 고정키(me|girlfriend), name은 화면에 보여줄 한글 이름
model User {
  id    String @id @default(cuid())
  role  String @unique
  name  String
  trips Trip[]
  plans Plan[]
}

/// 한 번의 추천 요청 (조건 + 결과 후보들)
model Trip {
  id          String   @id @default(cuid())
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  startDate   DateTime
  endDate     DateTime
  nights      Int
  origin      String // 출발지 (기본: 원주)
  style       String // hotel | sightseeing | food
  wantsDessert Boolean @default(false)
  mode        String   @default("recommend") // recommend(후보 3개 추천) | destination(가고싶은 곳 지정)
  isOverseas  Boolean  @default(false) // destination 모드에서 해외 여부
  destination String? // destination 모드에서 사용자가 정한 여행지
  status      String   @default("proposed") // proposed | confirmed
  createdAt   DateTime @default(now())

  options TripOption[]

  @@index([createdAt])
}

/// 추천된 지역 후보 하나
model TripOption {
  id                   String  @id @default(cuid())
  trip                 Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId               String
  regionName           String // 예: "강릉"
  summary              String // 왜 이 지역인지 한줄 요약
  estDriveMinutes      Int // 출발지 기준 편도 예상 운전시간(분)
  stayAreaNote         String? // 숙소는 이 근처가 좋다는 설명
  itinerary            String? // 일자별 코스 (JSON 문자열)
  overseasInfo         String? // 해외 여행 정보 — 항공·물가·꿀팁 등 (JSON 문자열)
  isChosen             Boolean @default(false)

  places Place[]
}

/// 저장하거나 확정한 여행.
/// 추천(TripOption)에서 복사해오며, 이후 편집은 전부 여기서만 일어납니다.
/// 원본 추천을 그대로 두기 위해 별도 테이블로 분리했습니다.
model Plan {
  id             String    @id @default(cuid())
  title          String // 예: "강릉 여행"
  regionName     String
  style          String // hotel | sightseeing | food
  origin         String
  startDate      DateTime
  endDate        DateTime
  nights         Int
  status         String    @default("saved") // saved | upcoming | completed
  memo           String?
  rating         Int? // 1~5, 다녀온 뒤
  review         String? // 한줄 후기
  completedAt    DateTime?
  savedBy        User      @relation(fields: [savedById], references: [id])
  savedById      String
  sourceOptionId String? // 어느 추천에서 왔는지 (원본 추적용)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  days PlanDay[]

  @@index([startDate])
  @@index([status])
  @@index([sourceOptionId])
}

/// 확정 여행의 하루치 일정
model PlanDay {
  id        String  @id @default(cuid())
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId    String
  dayNumber Int
  title     String?
  memo      String? // AI가 써준 코스 설명 + 사용자 메모

  items PlanItem[]

  @@unique([planId, dayNumber])
}

/// 하루 안의 방문지 하나 (순서 변경/시간 지정 가능)
model PlanItem {
  id            String  @id @default(cuid())
  day           PlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  dayId         String
  sortOrder     Int
  type          String // stay | food | dessert | activity
  name          String
  address       String?
  lat           Float?
  lng           Float?
  kakaoPlaceUrl String?
  photoUrl      String?
  note          String?
  priceLevel    String?
  visitTime     String? // "12:30"

  @@index([dayId, sortOrder])
}

/// 후보에 딸린 실제 장소 (숙소/맛집/디저트/액티비티)
model Place {
  id           String  @id @default(cuid())
  option       TripOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId     String
  type         String // stay | food | dessert | activity
  name         String
  address      String?
  lat          Float?
  lng          Float?
  kakaoPlaceUrl String?
  photoUrl     String? // 카카오 이미지 검색 썸네일
  note         String? // 플래너의 코멘트
  priceLevel   String? // 가성비/보통/프리미엄
}
